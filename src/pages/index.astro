---
import {
  categoryLabels,
  letterPronunciations,
  phoneticCategories,
  phoneticSymbols,
} from '@/data/phoneticSymbols'
import '@/styles/global.css'

const symbolsByCategory = Object.groupBy(phoneticSymbols, (item) => item.category)
const phoneticSymbolsById = new Map(phoneticSymbols.map((item) => [item.id, item]))
const letterPronunciationCards = letterPronunciations.map((group) => ({
  ...group,
  pronunciations: group.pronunciations.map((item) => {
    const phoneme = item.phonemeId ? phoneticSymbolsById.get(item.phonemeId) : null
    if (item.phonemeId && !phoneme) throw new Error(`Unknown phoneme id: ${item.phonemeId}`)
    const symbol = item.symbol ?? phoneme?.symbol
    if (!symbol) throw new Error('Letter pronunciation needs either a phonemeId or a symbol')

    return {
      ...item,
      symbol,
      audio: phoneme?.audio,
    }
  }),
}))

type FilterField = 'all' | 'family' | 'category' | 'length' | 'manner' | 'voicing'
type FilterOption = {
  id: string
  label: string
  field: FilterField
  value: string
}
type FilterGroup = {
  label: string
  ariaLabel?: string
  options: readonly FilterOption[]
}

const rangeFilterGroup: FilterGroup = {
  label: '范围',
  options: [
    { id: 'all', label: '全部', field: 'all', value: 'all' },
    { id: 'vowel', label: '元音', field: 'family', value: 'vowel' },
    { id: 'consonant', label: '辅音', field: 'family', value: 'consonant' },
  ],
}
const vowelFilterGroup: FilterGroup = {
  label: '元音',
  options: [
    { id: 'monophthong', label: '单元音', field: 'category', value: 'monophthong' },
    { id: 'diphthong', label: '双元音', field: 'category', value: 'diphthong' },
    { id: 'long-monophthong', label: '长单元音', field: 'length', value: 'long' },
    { id: 'short-monophthong', label: '短单元音', field: 'length', value: 'short' },
  ],
}
const mannerFilterGroup: FilterGroup = {
  label: '辅音方式',
  ariaLabel: '辅音发音方式',
  options: [
    { id: 'plosive', label: '爆破音', field: 'manner', value: 'plosive' },
    { id: 'fricative', label: '摩擦音', field: 'manner', value: 'fricative' },
    { id: 'affricate', label: '破擦音', field: 'manner', value: 'affricate' },
    { id: 'nasal', label: '鼻音', field: 'manner', value: 'nasal' },
    { id: 'lateral', label: '舌侧音', field: 'manner', value: 'lateral' },
    { id: 'semivowel', label: '半元音', field: 'manner', value: 'semivowel' },
  ],
}
const voicingFilterGroup: FilterGroup = {
  label: '清浊',
  ariaLabel: '辅音清浊',
  options: [
    { id: 'voiceless', label: '清辅音', field: 'voicing', value: 'voiceless' },
    { id: 'voiced', label: '浊辅音', field: 'voicing', value: 'voiced' },
  ],
}
const filterRows = [
  { label: '基础筛选', groups: [rangeFilterGroup, vowelFilterGroup] },
  { label: '辅音筛选', groups: [mannerFilterGroup, voicingFilterGroup] },
] satisfies readonly { label: string; groups: readonly FilterGroup[] }[]

const cx = (...classes: string[]) => classes.join(' ')

const panelClass = 'rounded-ipa border border-rule bg-panel shadow-ipa'
const filterButtonClass =
  "ipa-filter min-h-8.5 cursor-pointer touch-manipulation rounded-full border border-rule bg-filter-bg px-3.25 py-1.25 text-filter leading-compact text-muted transition-[background-color,border-color,color] duration-150 ease-in-out hover:border-rule-hover hover:bg-filter-hover hover:text-text focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-focus-ring [&[aria-pressed='true']]:border-filter-selected-border [&[aria-pressed='true']]:bg-accent-soft [&[aria-pressed='true']]:font-bold [&[aria-pressed='true']]:text-accent"
const letterButtonClass =
  "letter-tab flex size-9 cursor-pointer touch-manipulation items-center justify-center rounded-full border border-rule bg-filter-bg font-mono text-filter leading-none font-bold text-muted transition-[background-color,border-color,color] duration-150 ease-in-out hover:border-rule-hover hover:bg-filter-hover hover:text-text focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-focus-ring [&[aria-pressed='true']]:border-filter-selected-border [&[aria-pressed='true']]:bg-accent-soft [&[aria-pressed='true']]:text-accent"
const letterSoundButtonClass =
  'letter-sound group/sound relative flex min-h-19 cursor-pointer touch-manipulation flex-col items-start justify-between gap-2 rounded-lg border border-rule bg-symbol-bg px-3.5 py-3 text-left text-text transition-[background-color,border-color,color] duration-150 ease-in-out hover:border-rule-hover hover:bg-symbol-hover active:bg-symbol-active focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-focus-ring disabled:cursor-default disabled:opacity-100 disabled:hover:border-rule disabled:hover:bg-symbol-bg [&.is-loading]:border-symbol-loading-border [&.is-loading]:bg-symbol-loading-bg [&.is-loading]:text-accent [&.is-playing]:border-symbol-playing-border [&.is-playing]:bg-symbol-playing-bg [&.is-playing]:text-accent'
type PhoneticCategory = (typeof phoneticCategories)[number]
const getGroupLayoutClass = (category: PhoneticCategory) => {
  switch (category) {
    case 'monophthong':
      return 'col-span-7 max-ipa-tablet:col-span-full'
    case 'diphthong':
      return 'col-span-5 max-ipa-tablet:col-span-full'
    case 'consonant':
      return 'col-span-full'
  }
}
const symbolButtonClass =
  'ipa-symbol group/symbol relative inline-flex min-h-9 cursor-pointer touch-manipulation items-center justify-start gap-2 rounded-lg border border-rule bg-symbol-bg px-3.5 py-1 text-text transition-[background-color,border-color,color] duration-150 ease-in-out hover:border-rule-hover hover:bg-symbol-hover active:bg-symbol-active focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-focus-ring [&.is-loading]:border-symbol-loading-border [&.is-loading]:bg-symbol-loading-bg [&.is-loading]:text-accent [&.is-playing]:border-symbol-playing-border [&.is-playing]:bg-symbol-playing-bg [&.is-playing]:text-accent'
const repeatOptions = [1, 2, 3, 4, 5]
const currentYear = new Date().getFullYear()
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="音标有谱：英语48个音标试听页，按元音、辅音、长短音、发音方式和清浊分类筛选。"
    />
    <link rel="preload" href="/fonts/LXGWWenKaiScreen.ttf" as="font" type="font/ttf" crossorigin />
    <title>音标有谱</title>
  </head>
  <body>
    <main
      class="ipa-shell mx-auto flex min-h-screen w-ipa-shell flex-col pt-8.5 pb-7 max-ipa-tablet:w-ipa-shell-tablet max-ipa-tablet:pt-5.5"
    >
      <section
        class="grid grid-cols-ipa-hero items-end gap-7 border-b border-rule pt-3 pb-7 max-ipa-tablet:grid-cols-1 max-ipa-tablet:gap-4.5"
        aria-labelledby="page-title"
      >
        <div>
          <p class="mb-2.5 font-mono text-kicker font-bold tracking-[0.08em] text-accent uppercase">
            pronunciation notes
          </p>
          <h1 id="page-title" class="m-0 text-hero leading-hero font-hero tracking-normal">
            音标有谱
          </h1>
          <p class="mt-3.5 max-w-136 text-lead text-muted">
            点击音标听一遍，停下来模仿，再继续下一个声音。
          </p>
        </div>

        <aside class="grid grid-cols-2 gap-2.5 max-ipa-phone:grid-cols-1" aria-label="音标概览">
          <div class={cx(panelClass, 'grid min-h-18.5 content-center px-4 py-3.5')}>
            <strong class="text-summary-number leading-none">{phoneticSymbols.length}</strong>
            <span class="text-summary-label text-muted">个音标</span>
          </div>
          <div class={cx(panelClass, 'grid min-h-18.5 content-center px-4 py-3.5')}>
            <strong class="text-summary-number leading-none">2</strong>
            <span class="text-summary-label text-muted">大类</span>
          </div>
          <div
            class={cx(
              'ipa-status',
              panelClass,
              'col-span-full flex min-h-14 items-center gap-3 px-4 py-3.25 text-muted',
            )}
            id="status"
            role="status"
            aria-live="polite"
          >
            <span class="status-dot size-2.25 flex-none rounded-full bg-faint" aria-hidden="true"
            ></span>
            <span id="status-text">选择一个音标开始播放</span>
          </div>
        </aside>
      </section>

      <section
        class={cx(
          panelClass,
          'my-4.5 flex items-center justify-between gap-3 px-4.5 py-3.5 max-ipa-phone:flex-col max-ipa-phone:items-start',
        )}
        aria-label="使用提示和播放设置"
      >
        <p class="m-0 text-muted">
          建议顺序：先听元音，再听辅音；遇到相近音时连续点听，比较口型和气流差别。
        </p>
        <label class="inline-flex flex-none items-center gap-2 text-filter text-muted">
          <span class="font-bold whitespace-nowrap text-faint">循环</span>
          <select
            id="repeat-count"
            class="h-8 cursor-pointer rounded-full border border-rule bg-filter-bg px-3 py-1 leading-compact text-text outline-none transition-[background-color,border-color] duration-150 ease-in-out hover:border-rule-hover hover:bg-filter-hover focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-focus-ring"
            aria-label="每个音标自动循环播放次数"
          >
            {repeatOptions.map((count) => <option value={count}>{count} 次</option>)}
          </select>
        </label>
      </section>

      <section class={cx(panelClass, 'mb-4.5 p-4.5')} aria-labelledby="letter-pronunciation-title">
        <header
          class="mb-3.5 flex items-end justify-between gap-4 border-b border-rule pb-3 max-ipa-phone:flex-col max-ipa-phone:items-start"
        >
          <div>
            <p
              class="mb-1 font-mono text-group-eyebrow font-bold tracking-[0.08em] text-faint uppercase"
            >
              letter sounds
            </p>
            <h2 id="letter-pronunciation-title" class="m-0 text-group-title leading-compact">
              字母读音
            </h2>
          </div>
          <div class="flex flex-wrap gap-2" role="tablist" aria-label="按字母查看常见读音">
            {
              letterPronunciationCards.map((group, index) => (
                <button
                  class={letterButtonClass}
                  type="button"
                  role="tab"
                  data-letter-tab={group.letter}
                  aria-controls={`letter-panel-${group.letter}`}
                  aria-selected={index === 0 ? 'true' : 'false'}
                  aria-pressed={index === 0 ? 'true' : 'false'}
                >
                  {group.letter}
                </button>
              ))
            }
          </div>
        </header>

        {
          letterPronunciationCards.map((group, index) => (
            <section
              id={`letter-panel-${group.letter}`}
              class="letter-panel grid grid-cols-[7rem_minmax(0,1fr)] gap-4 max-ipa-tablet:grid-cols-1"
              data-letter-panel={group.letter}
              role="tabpanel"
              hidden={index !== 0}
            >
              <div class="flex flex-col items-center justify-between rounded-lg border border-rule bg-filter-bg px-4 py-3 text-center">
                <span class="flex items-end justify-center gap-1 font-mono leading-none font-bold text-text">
                  <span class="text-[3rem]">{group.letter}</span>
                  <span class="pb-1 text-summary-number text-muted">
                    {group.letter.toLowerCase()}
                  </span>
                </span>
                <span class="text-count text-muted">{group.pronunciations.length} 种读音</span>
              </div>
              <div class="grid grid-cols-2 gap-2 max-ipa-phone:grid-cols-1">
                {group.pronunciations.map((item) => (
                  <button
                    class={letterSoundButtonClass}
                    type="button"
                    data-letter-sound={group.letter}
                    data-symbol={item.symbol}
                    data-audio={item.audio}
                    data-examples={item.examples.join(', ')}
                    disabled={!item.audio}
                    aria-pressed="false"
                    aria-label={`${group.letter} 发 ${item.symbol}，例词 ${item.examples.join(', ')}${item.note ? `，${item.note}` : ''}`}
                    title={`${group.letter} 发 ${item.symbol}，例词 ${item.examples.join(', ')}${item.note ? `，${item.note}` : ''}`}
                  >
                    <span class="flex w-full items-baseline justify-between gap-3">
                      <span class="font-ipa-symbol text-symbol leading-symbol font-bold tracking-normal">
                        {item.symbol}
                      </span>
                      {item.audio ? (
                        <span class="ipa-symbol__play relative inline-flex size-5 flex-none items-center justify-center rounded-full border border-play-border text-faint transition-[background-color,border-color,color] duration-150 ease-in-out group-hover/sound:border-current group-hover/sound:text-current group-[.is-loading]/sound:border-current group-[.is-loading]/sound:bg-play-loading-bg group-[.is-loading]/sound:text-current group-[.is-playing]/sound:border-current group-[.is-playing]/sound:bg-play-playing-bg group-[.is-playing]/sound:text-current">
                          <span class="ipa-symbol__play-icon" />
                        </span>
                      ) : (
                        <span class="rounded-full border border-rule px-2 py-0.5 text-filter-label leading-none text-faint">
                          暂无音频
                        </span>
                      )}
                    </span>
                    <span class="text-filter leading-compact text-muted">
                      {item.examples.join(' / ')}
                    </span>
                    {item.note && (
                      <span class="text-filter-label leading-compact text-faint">{item.note}</span>
                    )}
                  </button>
                ))}
              </div>
            </section>
          ))
        }
      </section>

      <section
        class="mb-4.5 flex items-center gap-3 max-ipa-tablet:flex-col max-ipa-tablet:items-start"
        aria-label="音标筛选"
      >
        <div class="grid w-full min-w-0 flex-1 auto-rows-auto gap-2">
          {
            filterRows.map((row) => (
              <div
                class="flex min-w-0 flex-wrap items-center gap-x-4.5 gap-y-2 max-ipa-tablet:w-full max-ipa-tablet:flex-col max-ipa-tablet:items-start"
                aria-label={row.label}
              >
                {row.groups.map((group) => (
                  <div
                    class="flex min-w-0 items-center gap-1.75 max-ipa-tablet:w-full max-ipa-tablet:flex-col max-ipa-tablet:items-start max-ipa-tablet:gap-1.5"
                    role="group"
                    aria-label={`按${group.ariaLabel ?? group.label}筛选`}
                  >
                    <span class="flex-none text-filter-label leading-compact font-bold whitespace-nowrap text-faint max-ipa-tablet:basis-auto max-ipa-tablet:text-left">
                      {group.label}
                    </span>
                    <div class="flex min-w-0 flex-wrap gap-2">
                      {group.options.map((filter) => (
                        <button
                          class={filterButtonClass}
                          type="button"
                          data-filter={filter.id}
                          aria-pressed={filter.id === 'all' ? 'true' : 'false'}
                        >
                          {filter.label}
                        </button>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            ))
          }
        </div>
      </section>

      <section class="grid grid-cols-12 gap-3.5" aria-label="音标有谱">
        {
          phoneticCategories.map((category) => {
            const label = categoryLabels[category]
            const items = symbolsByCategory[category] ?? []
            const family = category === 'consonant' ? 'consonant' : 'vowel'

            return (
              <section
                class={cx(
                  `ipa-group ipa-group--${category}`,
                  panelClass,
                  getGroupLayoutClass(category),
                  'p-4.5',
                )}
                aria-labelledby={`${category}-title`}
                data-category={category}
                data-family={family}
                data-default-title={label.title}
                data-default-eyebrow={label.eyebrow}
              >
                <header class="mb-3.5 flex items-baseline justify-between gap-3.5 border-b border-rule pb-2.5">
                  <div>
                    <p
                      class="mb-1 font-mono text-group-eyebrow font-bold tracking-[0.08em] text-faint uppercase"
                      data-eyebrow
                    >
                      {label.eyebrow}
                    </p>
                    <h2
                      id={`${category}-title`}
                      class="m-0 text-group-title leading-compact"
                      data-title
                    >
                      {label.title}
                    </h2>
                  </div>
                  <span class="text-count whitespace-nowrap text-muted" data-count>
                    {items.length} 个
                  </span>
                </header>

                <div class="grid grid-cols-ipa-symbols gap-2 max-ipa-tablet:grid-cols-ipa-symbols-tablet max-ipa-phone:grid-cols-ipa-symbols-phone">
                  {items.map((item) => (
                    <button
                      class={symbolButtonClass}
                      type="button"
                      data-symbol={item.symbol}
                      data-audio={item.audio}
                      data-family={item.family}
                      data-category={item.category}
                      data-length={item.length}
                      data-manner={item.manner}
                      data-voicing={item.voicing}
                      data-letters={item.letters}
                      aria-pressed="false"
                      aria-label={`播放 ${item.symbol}，常见拼写 ${item.letters}`}
                      title={`播放 ${item.symbol}，常见拼写 ${item.letters}`}
                    >
                      <span
                        class="pointer-events-none absolute top-px right-1 font-sans text-[0.5rem] leading-none font-normal tracking-normal whitespace-nowrap text-faint opacity-45"
                        aria-hidden="true"
                      >
                        {item.letters}
                      </span>
                      <span
                        class="ipa-symbol__play relative inline-flex size-5 flex-none translate-y-px items-center justify-center rounded-full border border-play-border text-faint transition-[background-color,border-color,color] duration-150 ease-in-out group-hover/symbol:border-current group-hover/symbol:text-current group-[.is-loading]/symbol:border-current group-[.is-loading]/symbol:bg-play-loading-bg group-[.is-loading]/symbol:text-current group-[.is-playing]/symbol:border-current group-[.is-playing]/symbol:bg-play-playing-bg group-[.is-playing]/symbol:text-current"
                        aria-hidden="true"
                      >
                        <span class="ipa-symbol__play-icon" />
                      </span>
                      <span class="font-ipa-symbol text-symbol leading-symbol inline-flex h-5 min-w-0 flex-initial items-center text-center font-bold tracking-normal">
                        {item.symbol}
                      </span>
                    </button>
                  ))}
                </div>
              </section>
            )
          })
        }
      </section>

      <footer
        class="text-footer mt-auto flex justify-center pt-7 pb-2.5 text-muted max-ipa-tablet:pt-5.5 max-ipa-tablet:pb-2"
      >
        <div class="inline-flex flex-col items-start gap-1.5 text-left">
          <span>音标有谱 · 英语 48 个音标</span>
          <span class="inline-flex flex-wrap gap-2">
            <span>词词有据 ·</span>
            <a
              class="font-bold text-accent"
              href="https://english-roots.netlify.app"
              target="_blank"
              rel="noreferrer"
            >
              english-roots.netlify.app
            </a>
          </span>
          <span class="inline-flex flex-wrap gap-2">
            <span>©{currentYear} 未有期. All rights reserved.</span>
          </span>
          <span class="inline-flex flex-wrap gap-2">
            <span>本项目仅用于学习目的，音标内容版权归原网站所有。</span>
            <a
              class="font-bold text-accent"
              href="https://www.yyybabc.com/"
              target="_blank"
              rel="noreferrer"
            >
              yyybabc.com
            </a>
          </span>
        </div>
      </footer>
    </main>

    <audio id="player" preload="none"></audio>

    <script>
      const player = document.querySelector<HTMLAudioElement>('#player')
      const status = document.querySelector<HTMLElement>('#status')
      const statusText = document.querySelector('#status-text')
      const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>('.ipa-symbol'))
      const letterSoundButtons = Array.from(
        document.querySelectorAll<HTMLButtonElement>('.letter-sound'),
      )
      const filterButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('.ipa-filter'))
      const letterTabButtons = Array.from(
        document.querySelectorAll<HTMLButtonElement>('.letter-tab'),
      )
      const letterPanels = Array.from(document.querySelectorAll<HTMLElement>('.letter-panel'))
      const groups = Array.from(document.querySelectorAll<HTMLElement>('.ipa-group'))
      const repeatSelect = document.querySelector<HTMLSelectElement>('#repeat-count')
      let activeButton: HTMLButtonElement | null = null
      let activePlayToken = 0
      let activeRepeatIndex = 0
      let repeatCount = 1
      const repeatStorageKey = 'english-ipa-repeat-count'

      const filterRules = {
        all: { field: 'all', value: 'all', useDefaultHeading: true },
        vowel: { field: 'family', value: 'vowel', useDefaultHeading: true },
        consonant: { field: 'family', value: 'consonant', useDefaultHeading: true },
        monophthong: {
          field: 'category',
          value: 'monophthong',
          title: '单元音',
          eyebrow: 'Monophthongs',
        },
        diphthong: {
          field: 'category',
          value: 'diphthong',
          title: '双元音',
          eyebrow: 'Diphthongs',
        },
        'long-monophthong': {
          field: 'length',
          value: 'long',
          title: '长单元音',
          eyebrow: 'Long monophthongs',
        },
        'short-monophthong': {
          field: 'length',
          value: 'short',
          title: '短单元音',
          eyebrow: 'Short monophthongs',
        },
        plosive: { field: 'manner', value: 'plosive', title: '爆破音', eyebrow: 'Plosives' },
        fricative: { field: 'manner', value: 'fricative', title: '摩擦音', eyebrow: 'Fricatives' },
        affricate: { field: 'manner', value: 'affricate', title: '破擦音', eyebrow: 'Affricates' },
        nasal: { field: 'manner', value: 'nasal', title: '鼻音', eyebrow: 'Nasals' },
        lateral: {
          field: 'manner',
          value: 'lateral',
          title: '舌侧音',
          eyebrow: 'Lateral consonants',
        },
        semivowel: { field: 'manner', value: 'semivowel', title: '半元音', eyebrow: 'Semivowels' },
        voiceless: {
          field: 'voicing',
          value: 'voiceless',
          title: '清辅音',
          eyebrow: 'Voiceless consonants',
        },
        voiced: {
          field: 'voicing',
          value: 'voiced',
          title: '浊辅音',
          eyebrow: 'Voiced consonants',
        },
      } as const

      type FilterId = keyof typeof filterRules
      type ClientFilterField = (typeof filterRules)[FilterId]['field']

      function resetStatus() {
        if (statusText) statusText.textContent = '选择一个音标开始播放'
        if (status) status.dataset.state = 'idle'
      }

      function setErrorStatus(text: string) {
        if (statusText) statusText.textContent = text
        if (status) status.dataset.state = 'error'
      }

      function setPlayingStatus(button: HTMLButtonElement) {
        const symbol = button.dataset.symbol ?? ''
        const letter = button.dataset.letterSound
        const examples = button.dataset.examples

        if (!statusText) return
        if (letter && examples) {
          statusText.textContent = `${letter} 发 ${symbol}：${examples}`
          return
        }
        statusText.textContent = `正在播放 ${symbol}`
      }

      function clearActive() {
        if (activeButton) {
          activeButton.classList.remove('is-loading')
          activeButton.classList.remove('is-playing')
          activeButton.setAttribute('aria-pressed', 'false')
        }
        activeButton = null
      }

      function stopActivePlayback(shouldResetStatus = true) {
        activePlayToken += 1
        activeRepeatIndex = 0
        player?.pause()
        if (player) player.currentTime = 0
        clearActive()
        if (shouldResetStatus) resetStatus()
      }

      function getValidRepeatCount(value: unknown) {
        const count = typeof value === 'number' ? value : Number.parseInt(String(value), 10)
        return Number.isInteger(count) && count >= 1 && count <= 5 ? count : 1
      }

      function loadRepeatCount() {
        try {
          return getValidRepeatCount(window.localStorage.getItem(repeatStorageKey))
        } catch {
          return 1
        }
      }

      function setRepeatCount(value: unknown, shouldPersist = true) {
        repeatCount = getValidRepeatCount(value)
        if (repeatSelect) repeatSelect.value = String(repeatCount)

        if (!shouldPersist) return
        try {
          window.localStorage.setItem(repeatStorageKey, String(repeatCount))
        } catch {
          // Storage can be unavailable in private browsing; playback should still work.
        }
      }

      function getFilterRule(filter: string) {
        if (filter in filterRules) return filterRules[filter as FilterId]
        console.warn(`Unknown IPA filter: ${filter}`)
        return null
      }

      function getButtonFilterValue(button: HTMLButtonElement, field: ClientFilterField) {
        switch (field) {
          case 'family':
            return button.dataset.family
          case 'category':
            return button.dataset.category
          case 'length':
            return button.dataset.length
          case 'manner':
            return button.dataset.manner
          case 'voicing':
            return button.dataset.voicing
          case 'all':
            return 'all'
        }
      }

      function matchesFilter(button: HTMLButtonElement, filter: string) {
        const rule = getFilterRule(filter)
        if (!rule) return false
        if (rule.field === 'all') return true
        return getButtonFilterValue(button, rule.field) === rule.value
      }

      function selectLetter(letter: string) {
        if (
          activeButton?.classList.contains('letter-sound') &&
          activeButton.dataset.letterSound !== letter
        ) {
          stopActivePlayback()
        }

        letterTabButtons.forEach((button) => {
          const isSelected = button.dataset.letterTab === letter
          button.setAttribute('aria-selected', String(isSelected))
          button.setAttribute('aria-pressed', String(isSelected))
        })

        letterPanels.forEach((panel) => {
          panel.hidden = panel.dataset.letterPanel !== letter
        })
      }

      function updateGroupHeading(group: HTMLElement, filter: string) {
        const rule = getFilterRule(filter)
        const title = group.querySelector<HTMLElement>('[data-title]')
        const eyebrow = group.querySelector<HTMLElement>('[data-eyebrow]')
        const defaultTitle = group.dataset.defaultTitle ?? ''
        const defaultEyebrow = group.dataset.defaultEyebrow ?? ''
        const shouldUseDefault = !rule || 'useDefaultHeading' in rule

        if (title)
          title.textContent = shouldUseDefault ? defaultTitle : (rule.title ?? defaultTitle)
        if (eyebrow)
          eyebrow.textContent = shouldUseDefault ? defaultEyebrow : (rule.eyebrow ?? defaultEyebrow)
      }

      function applyFilter(filter: string) {
        const shouldClearActive = activeButton?.classList.contains('ipa-symbol')
          ? !matchesFilter(activeButton, filter)
          : false

        if (shouldClearActive) {
          stopActivePlayback()
        }

        filterButtons.forEach((button) => {
          button.setAttribute('aria-pressed', String(button.dataset.filter === filter))
        })

        groups.forEach((group) => {
          const groupButtons = Array.from(group.querySelectorAll<HTMLButtonElement>('.ipa-symbol'))
          const count = group.querySelector<HTMLElement>('[data-count]')
          let visibleCount = 0

          groupButtons.forEach((button) => {
            const isVisible = matchesFilter(button, filter)
            button.hidden = !isVisible
            if (isVisible) visibleCount += 1
          })

          group.hidden = visibleCount === 0
          updateGroupHeading(group, filter)
          if (count) count.textContent = `${visibleCount} 个`
        })
      }

      async function playSymbol(button: HTMLButtonElement) {
        if (!player) return
        if (button.hidden) return

        const symbol = button.dataset.symbol ?? ''
        const audio = button.dataset.audio
        if (!audio) return

        stopActivePlayback(false)
        activePlayToken += 1
        const playToken = activePlayToken

        activeButton = button
        activeRepeatIndex = 1
        button.classList.add('is-loading')
        button.setAttribute('aria-pressed', 'true')
        player.src = audio
        resetStatus()

        try {
          await player.play()

          if (activeButton !== button || activePlayToken !== playToken) {
            return
          }

          button.classList.remove('is-loading')
          button.classList.add('is-playing')
          setPlayingStatus(button)
        } catch {
          if (activePlayToken !== playToken) return
          clearActive()
          setErrorStatus(`${symbol} 播放失败，请再试一次`)
        }
      }

      buttons.forEach((button) => {
        button.addEventListener('click', () => {
          playSymbol(button)
        })
      })

      letterSoundButtons.forEach((button) => {
        button.addEventListener('click', () => {
          playSymbol(button)
        })
      })

      letterTabButtons.forEach((button) => {
        button.addEventListener('click', () => {
          selectLetter(button.dataset.letterTab ?? 'A')
        })
      })

      filterButtons.forEach((button) => {
        button.addEventListener('click', () => {
          applyFilter(button.dataset.filter ?? 'all')
        })
      })

      repeatSelect?.addEventListener('change', () => {
        setRepeatCount(repeatSelect.value)
      })

      setRepeatCount(loadRepeatCount(), false)

      player?.addEventListener('ended', async () => {
        if (!player || !activeButton) {
          clearActive()
          resetStatus()
          return
        }

        if (activeRepeatIndex >= repeatCount) {
          clearActive()
          resetStatus()
          activeRepeatIndex = 0
          return
        }

        const button = activeButton
        const symbol = button.dataset.symbol ?? ''
        const playToken = activePlayToken
        activeRepeatIndex += 1
        player.currentTime = 0

        try {
          await player.play()

          if (activeButton !== button || activePlayToken !== playToken) {
            return
          }

          button.classList.remove('is-loading')
          button.classList.add('is-playing')
          button.setAttribute('aria-pressed', 'true')
          setPlayingStatus(button)
        } catch {
          if (activePlayToken !== playToken) return
          clearActive()
          setErrorStatus(`${symbol} 播放失败，请再试一次`)
        }
      })

      player?.addEventListener('error', () => {
        activePlayToken += 1
        activeRepeatIndex = 0
        clearActive()
        setErrorStatus('音频加载失败，请确认本地音频文件存在')
      })
    </script>
  </body>
</html>
